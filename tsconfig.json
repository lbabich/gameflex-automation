{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": [
    "src/server/tests/**/*.ts",
    "src/server/lib/**/*.ts",
    "playwright.config.ts",
    "src/server/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
