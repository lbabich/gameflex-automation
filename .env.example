# Claude API key for vision-based discovery
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Run browser in headless mode (1=headless, 0=visible). Default: 1
PW_HEADLESS=1

# HTTP Basic Auth credentials (optional — only needed for password-protected environments)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Game URLs are configured in tests/games.ts
